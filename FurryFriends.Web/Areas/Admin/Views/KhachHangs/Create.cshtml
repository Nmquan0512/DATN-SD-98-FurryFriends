@model FurryFriends.API.Models.KhachHang

@{
    ViewData["Title"] = "Thêm khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="main-content" id="mainContent">
    <div class="top-bar mb-3">
        <h1>@ViewData["Title"]</h1>
        <div class="user-info" role="region" aria-label="User information">
            <span>Admin</span>
            <div class="avatar" aria-hidden="true">AD</div>
        </div>
    </div>

    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="Admin">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="KhachHang" asp-action="Index" asp-area="Admin">Quản lý khách hàng</a></li>
        <li class="breadcrumb-item active">Thêm khách hàng</li>
    </ol>

    <div class="card shadow mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <i class="fas fa-plus-circle me-2"></i>
            <span class="fw-bold">Thêm khách hàng mới</span>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="TenKhachHang" class="form-label fw-semibold"></label>
                    <input asp-for="TenKhachHang" class="form-control" placeholder="Nhập tên khách hàng" />
                    <span asp-validation-for="TenKhachHang" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SDT" class="form-label fw-semibold"></label>
                    <input asp-for="SDT" class="form-control" placeholder="Nhập số điện thoại" />
                    <span asp-validation-for="SDT" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EmailCuaKhachHang" class="form-label fw-semibold"></label>
                    <input asp-for="EmailCuaKhachHang" class="form-control" placeholder="Nhập email" />
                    <span asp-validation-for="EmailCuaKhachHang" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DiemKhachHang" class="form-label fw-semibold"></label>
                    <input asp-for="DiemKhachHang" class="form-control" placeholder="Nhập điểm khách hàng" />
                    <span asp-validation-for="DiemKhachHang" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TaiKhoanId" class="form-label fw-semibold"></label>
                    <input asp-for="TaiKhoanId" class="form-control" placeholder="Nhập ID tài khoản liên kết" />
                    <span asp-validation-for="TaiKhoanId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TrangThai" class="form-label fw-semibold d-block"></label>
                    <select asp-for="TrangThai" class="form-select">
                        <option value="0">Chưa kích hoạt</option>
                        <option value="1">Đang hoạt động</option>
                        <option value="2">Đã khóa</option>
                    </select>
                    <span asp-validation-for="TrangThai" class="text-danger small d-block"></span>
                </div>

                <input type="hidden" asp-for="NgayTaoTaiKhoan" value="@DateTime.Now" />

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
