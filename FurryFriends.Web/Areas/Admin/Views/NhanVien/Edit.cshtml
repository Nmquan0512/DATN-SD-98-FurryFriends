@model FurryFriends.API.Models.NhanVien

@{
    ViewData["Title"] = "Sửa nhân viên";
}

<div class="container mt-4">
    <h2>Sửa thông tin nhân viên</h2>

    <form asp-action="Edit" method="post">
        <!-- Hiển thị lỗi tổng thể -->
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Các trường ẩn cần thiết -->
        <input type="hidden" asp-for="NhanVienId" />
        <input type="hidden" asp-for="NgayTao" />
        <input type="hidden" asp-for="TaiKhoanId" />

        <!-- Họ và tên -->
        <div class="form-group">
            <label asp-for="HoVaTen">Họ Và Tên</label>
            <input asp-for="HoVaTen" class="form-control" />
            <span asp-validation-for="HoVaTen" class="text-danger"></span>
        </div>

        <!-- Ngày sinh -->
        <div class="form-group">
            <label asp-for="NgaySinh">Ngày Sinh</label>
            <input asp-for="NgaySinh" type="date" class="form-control" />
            <span asp-validation-for="NgaySinh" class="text-danger"></span>
        </div>

        <!-- Giới tính -->
        <div class="form-group">
            <label asp-for="GioiTinh">Giới Tính</label>
            <select asp-for="GioiTinh" class="form-control">
                <option value="Nam">Nam</option>
                <option value="Nữ">Nữ</option>
            </select>
            <span asp-validation-for="GioiTinh" class="text-danger"></span>
        </div>

        <!-- Địa chỉ -->
        <div class="form-group">
            <label asp-for="DiaChi">Địa Chỉ</label>
            <input asp-for="DiaChi" class="form-control" />
            <span asp-validation-for="DiaChi" class="text-danger"></span>
        </div>

        <!-- Số điện thoại -->
        <div class="form-group">
            <label asp-for="SDT">Số Điện Thoại</label>
            <input asp-for="SDT" class="form-control" />
            <span asp-validation-for="SDT" class="text-danger"></span>
        </div>

        <!-- Email -->
        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <!-- Chức vụ -->
        <div class="form-group">
            <label asp-for="ChucVuId">Chức Vụ</label>
            <select asp-for="ChucVuId" class="form-control" asp-items="ViewBag.ChucVuId"></select>
            <span asp-validation-for="ChucVuId" class="text-danger"></span>
        </div>

        <!-- Trạng thái -->
        <div class="form-check mb-3">
            <input asp-for="TrangThai" class="form-check-input" />
            <label class="form-check-label" asp-for="TrangThai">Đang làm</label>
            <span asp-validation-for="TrangThai" class="text-danger"></span>
        </div>

        <!-- Nút -->
        <div>
            <button type="submit" class="btn btn-success">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

<!-- Scripts cho client-side validation -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}