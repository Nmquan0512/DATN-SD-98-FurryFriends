@model IEnumerable<FurryFriends.API.Models.NhanVien>

@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<div class="main-content" id="mainContent">
    <div class="top-bar">
        <h1>@ViewData["Title"]</h1>
        <li class="nav-item dropdown position-relative" style="list-style: none;">
            <button type="button" class="btn nav-link" id="notificationDropdown" style="background: none; border: none; margin-left: 900px">
                🔔 <span class="badge bg-danger" id="notificationCount">!</span>
            </button>
            <div id="notificationContent" class="dropdown-menu dropdown-menu-end" style="max-height: 300px; overflow-y: auto; position: absolute; max-width: 500px; margin-left: 500px">
                <!-- Nội dung sẽ được load tại đây -->
            </div>
        </li>
        <div class="user-info" role="region" aria-label="User information">
            <span>Admin</span>
            <div class="avatar" aria-hidden="true">AD</div>
        </div>
    </div>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active">Quản lý nhân viên</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div><i class="fas fa-users me-2"></i>Danh sách nhân viên</div>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="fas fa-plus"></i> Tạo mới
            </a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <!-- Tìm kiếm -->
            @* <form asp-action="Search" method="post" class="mb-3"> *@
            @*     <div class="input-group"> *@
            @*         <input type="text" name="hoVaTen" class="form-control" placeholder="Tìm theo họ và tên..." /> *@
            @*         <button type="submit" class="btn btn-outline-secondary">Tìm</button> *@
            @*     </div> *@
            @* </form> *@

            <div class="table-responsive">
            <table id="nhanVienTable" class="table table-bordered table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Họ và tên</th>
                        <th>Ngày sinh</th>
                        <th>Địa chỉ</th>
                        <th>SĐT</th>
                        <th>Email</th>
                        <th>Giới tính</th>
                        <th>Chức vụ</th>
                        <th>Tài khoản</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
           
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.HoVaTen</td>
                            <td>@item.NgaySinh.ToString("dd/MM/yyyy")</td>
                            <td>@item.DiaChi</td>
                            <td>@item.SDT</td>
                            <td>@item.Email</td>
                            <td>@item.GioiTinh</td>
                            <td>@(item.ChucVu != null ? item.ChucVu.TenChucVu : "N/A")</td>
                            <td>@(item.TaiKhoan != null ? item.TaiKhoan.UserName : "N/A")</td>
                            <td>
                                @(item.TrangThai ? "Hoạt động" : "Không hoạt động")
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.NhanVienId" class="btn btn-sm btn-warning me-1"><i class="fas fa-edit"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.NhanVienId" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#nhanVienTable').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json' },
                responsive: true,
                order: [[1, 'asc']]
            });
        });

        $(document).ready(function () {
            $('#notificationDropdown').on('click', function (e) {
                e.preventDefault();

                var dropdown = $('#notificationContent');

                // Toggle thủ công class .show
                dropdown.toggleClass('show');

                // Nếu đang hiển thị thì load dữ liệu
                if (dropdown.hasClass('show')) {
                    $.get('/Admin/LichSuThaoTacs/GetRecent', function (data) {
                        dropdown.html(data);
                    }).fail(function (xhr) {
                        console.error("Lỗi khi tải thông báo:", xhr.responseText);
                        dropdown.html('<div class="dropdown-item text-danger">Không thể tải thông báo</div>');
                    });
                } else {
                    // Nếu đang ẩn → xóa nội dung nếu bạn muốn
                    dropdown.empty();
                }
            });

            // Click ngoài dropdown thì ẩn đi
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#notificationDropdown').length &&
                    !$(e.target).closest('#notificationContent').length) {
                    $('#notificationContent').removeClass('show').empty();
                }
            });
        });
    </script>
}
