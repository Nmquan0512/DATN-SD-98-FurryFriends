@model IEnumerable<FurryFriends.API.Models.HoaDon>

@{
    ViewData["Title"] = "Quản lý hóa đơn";
}

<div class="main-content" id="mainContent">
    <div class="top-bar">
        <h1>@ViewData["Title"]</h1>
        <li class="nav-item dropdown position-relative" style="list-style: none;">
            <button type="button" class="btn nav-link" id="notificationDropdown" style="background: none; border: none; margin-left: 900px">
                🔔 <span class="badge bg-danger" id="notificationCount">!</span>
            </button>
            <div id="notificationContent" class="dropdown-menu dropdown-menu-end" style="max-height: 300px; overflow-y: auto; position: absolute; max-width: 500px; margin-left: 500px">
                <!-- Nội dung sẽ được load tại đây -->
            </div>
        </li>
        <div class="user-info" role="region" aria-label="User information">
            <span>Admin</span>
            <div class="avatar" aria-hidden="true">AD</div>
        </div>
    </div>

    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="Admin">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="HoaDon" asp-action="Index" asp-area="Admin">Quản lý hóa đơn</a></li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-table me-2"></i>
                <span>Danh sách hóa đơn</span>
            </div>
        </div>
        <div class="card-body">
            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["error"]
                </div>
            }
            <div class="table-responsive">
            <table id="hoaDonTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Mã hóa đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày tạo</th>
                        <th>Tổng tiền</th>
                        <th>Giảm giá</th>
                        <th>Thành tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.HoaDonId.ToString().Substring(0, 8).ToUpper()</td>
                            <td>
                                <div>@item.TenCuaKhachHang</div>
                                <small class="text-muted">@item.SdtCuaKhachHang</small>
                            </td>
                            <td>@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.TongTien.ToString("N0")đ</td>
                            <td>
                                @if (item.Voucher != null)
                                {
                                    <span class="badge bg-success">@item.Voucher.TenVoucher</span>
                                }
                                else
                                {
                                    <span class="text-muted">Không có</span>
                                }
                            </td>
                            <td>@item.TongTienSauKhiGiam.ToString("N0")đ</td>
                            <td>
                                @switch (item.TrangThai)
                                {
                                    case 0:
                                        <span class="badge bg-warning">Chờ xác nhận</span>
                                        break;
                                    case 1:
                                        <span class="badge bg-info">Đã xác nhận</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-primary">Đang giao</span>
                                        break;
                                    case 3:
                                        <span class="badge bg-success">Hoàn thành</span>
                                        break;
                                    case 4:
                                        <span class="badge bg-danger">Đã hủy</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">Không xác định</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Details", "HoaDon", new { area = "Admin", id = item.HoaDonId })" class="btn btn-info btn-sm action-btn">
                                        <i class="fas fa-eye"></i> Xem
                                    </a>
                                    <a href="@Url.Action("ExportPdf", "HoaDon", new { area = "Admin", id = item.HoaDonId })" class="btn btn-success btn-sm action-btn" target="_blank">
                                        <i class="fas fa-file-pdf"></i> PDF
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#hoaDonTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json',
                },
                order: [[2, 'desc']],
                responsive: true
            });

            // Xử lý click cho các button
            $('.action-btn').on('click', function (e) {
                var $btn = $(this);
                var originalText = $btn.html();
                var href = $btn.attr('href');



                // Nếu là link PDF, mở trong tab mới
                if (href.includes('ExportPdf')) {
                    window.open(href, '_blank');
                    setTimeout(function () {
                        $btn.html(originalText);
                        $btn.prop('disabled', false);
                    }, 1000);
                } else {
                    // Nếu là link Details, chuyển hướng ngay lập tức
                    window.location.href = href;
                }
            });
        });

        $(document).ready(function () {
            $('#notificationDropdown').on('click', function (e) {
                e.preventDefault();

                var dropdown = $('#notificationContent');

                // Toggle thủ công class .show
                dropdown.toggleClass('show');

                // Nếu đang hiển thị thì load dữ liệu
                if (dropdown.hasClass('show')) {
                    $.get('/Admin/LichSuThaoTacs/GetRecent', function (data) {
                        dropdown.html(data);
                    }).fail(function (xhr) {
                        console.error("Lỗi khi tải thông báo:", xhr.responseText);
                        dropdown.html('<div class="dropdown-item text-danger">Không thể tải thông báo</div>');
                    });
                } else {
                    // Nếu đang ẩn → xóa nội dung nếu bạn muốn
                    dropdown.empty();
                }
            });

            // Click ngoài dropdown thì ẩn đi
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#notificationDropdown').length &&
                    !$(e.target).closest('#notificationContent').length) {
                    $('#notificationContent').removeClass('show').empty();
                }
            });
        });
    </script>
}
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>