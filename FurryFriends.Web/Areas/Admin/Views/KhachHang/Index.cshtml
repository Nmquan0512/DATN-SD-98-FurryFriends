@model IEnumerable<FurryFriends.API.Models.KhachHang>

@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="main-content" id="mainContent">
    <div class="top-bar">
        <h1>@ViewData["Title"]</h1>
        <div class="user-info" role="region" aria-label="User information">
            <span>Admin</span>
            <div class="avatar" aria-hidden="true">AD</div>
        </div>
    </div>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="Admin">Trang chủ</a></li>
        <li class="breadcrumb-item active">Quản lý khách hàng</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-users me-2"></i>
                <span>Danh sách khách hàng</span>
            </div>
            <div>
                <a href="@Url.Action("Create", "KhachHang", new { area = "Admin" })" class="btn btn-success">
                    <i class="fas fa-plus"></i> Thêm mới
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["error"]
                </div>
            }
            <div class="table-responsive">
            <table id="khachHangTable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Tên khách hàng</th>
                        <th>Số điện thoại</th>
                        <th>Email</th>
                        <th>Điểm</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TenKhachHang</td>
                            <td>@item.SDT</td>
                            <td>@item.EmailCuaKhachHang</td>
                            <td>@item.DiemKhachHang</td>
                            <td>@item.NgayTaoTaiKhoan.ToString("dd/MM/yyyy")</td>
                            <td>
                                @switch (item.TrangThai)
                                {
                                    case 0:
                                        <span class="badge bg-warning">Chưa kích hoạt</span>
                                        break;
                                    case 1:
                                        <span class="badge bg-success">Đang hoạt động</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-danger">Đã khóa</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">Không xác định</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Details", "KhachHang", new { area = "Admin", id = item.KhachHangId })" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i> Xem
                                    </a>
                                    <a href="@Url.Action("Edit", "KhachHang", new { area = "Admin", id = item.KhachHangId })" class="btn btn-primary btn-sm">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Delete", "KhachHang", new { area = "Admin", id = item.KhachHangId })" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#khachHangTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json'
                },
                responsive: true,
                order: [[4, 'desc']]
            });
        });
    </script>
}
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>