@model IEnumerable<FurryFriends.API.Models.TaiKhoan>

@{
    ViewData["Title"] = "Danh sách tài khoản";
}

<div class="main-content" id="mainContent">
    <div class="top-bar">
        <h1>@ViewData["Title"]</h1>

        <li class="nav-item dropdown position-relative" style="list-style: none;">
            <button type="button" class="btn nav-link" id="notificationDropdown" style="background: none; border: none; margin-left: 900px">
                🔔 <span class="badge bg-danger" id="notificationCount">!</span>
            </button>
            <div id="notificationContent" class="dropdown-menu dropdown-menu-end" style="max-height: 300px; overflow-y: auto; position: absolute; max-width: 500px; margin-left: 500px">
                <!-- Nội dung sẽ được load tại đây -->
            </div>
        </li>
        <div class="user-info" role="region" aria-label="User information">
            <span>Admin</span>
            <div class="avatar" aria-hidden="true">AD</div>
        </div>
    </div>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active">Quản lý tài khoản</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div><i class="fas fa-user-lock me-2"></i>Danh sách tài khoản</div>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="fas fa-plus"></i> Tạo mới
            </a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
            <div class="table-responsive">
            <table id="taiKhoanTable" class="table table-bordered table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Tên đăng nhập</th>
                        <th>Ngày tạo</th>
                        <th>Cập nhật cuối</th>
                        <th>Loại tài khoản</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.UserName</td>
                            <td>@item.NgayTaoTaiKhoan.ToString("dd/MM/yyyy")</td>
                            <td>@(item.NgayCapNhatCuoiCung?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</td>
                            <td>
                                @if (item.NhanVien != null)
                                {
                                    <span class="badge bg-info text-dark">Nhân viên</span>
                                }
                                else if (item.KhachHang != null)
                                {
                                    <span class="badge bg-secondary">Khách hàng</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted">Chưa phân loại</span>
                                }
                            </td>
                            <td>
                                @if (item.TrangThai)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Bị khóa</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.TaiKhoanId" class="btn btn-sm btn-warning me-1"><i class="fas fa-edit"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.TaiKhoanId" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('#taiKhoanTable').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json' },
                responsive: true,
                order: [[1, 'desc']]
            });
        });

        $(document).ready(function () {
            $('#notificationDropdown').on('click', function (e) {
                e.preventDefault();

                var dropdown = $('#notificationContent');

                // Toggle thủ công class .show
                dropdown.toggleClass('show');

                // Nếu đang hiển thị thì load dữ liệu
                if (dropdown.hasClass('show')) {
                    $.get('/Admin/LichSuThaoTacs/GetRecent', function (data) {
                        dropdown.html(data);
                    }).fail(function (xhr) {
                        console.error("Lỗi khi tải thông báo:", xhr.responseText);
                        dropdown.html('<div class="dropdown-item text-danger">Không thể tải thông báo</div>');
                    });
                } else {
                    // Nếu đang ẩn → xóa nội dung nếu bạn muốn
                    dropdown.empty();
                }
            });

            // Click ngoài dropdown thì ẩn đi
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#notificationDropdown').length &&
                    !$(e.target).closest('#notificationContent').length) {
                    $('#notificationContent').removeClass('show').empty();
                }
            });
        });
    </script>
}
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>