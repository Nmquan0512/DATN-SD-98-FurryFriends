@model IEnumerable<FurryFriends.API.Models.NhanVien>

@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Tạo mới</a>
</p>

<form asp-action="Search" method="post" class="mb-3">
    <div class="input-group">
        <input type="text" name="hoVaTen" class="form-control" placeholder="Tìm theo họ và tên..." />
        <button type="submit" class="btn btn-outline-secondary">Tìm</button>
    </div>
</form>

<table class="table table-bordered table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Họ và tên</th>
            <th>Ngày sinh</th>
            <th>Địa chỉ</th>
            <th>Số điện thoại</th>
            <th>Email</th>
            <th>Giới tính</th>
            <th>Chức vụ</th>
            <th>Tài khoản</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.HoVaTen)</td>
                <td>@Html.DisplayFor(modelItem => item.NgaySinh)</td>
                <td>@Html.DisplayFor(modelItem => item.DiaChi)</td>
                <td>@Html.DisplayFor(modelItem => item.SDT)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.GioiTinh)</td>
                <td>@(item.ChucVu != null ? item.ChucVu.TenChucVu : "N/A")</td>
                <td>@(item.TaiKhoan != null ? item.TaiKhoan.UserName : "N/A")</td>
                <td>@(item.TrangThai ? "Hoạt động" : "Không hoạt động")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.NhanVienId" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.NhanVienId" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}