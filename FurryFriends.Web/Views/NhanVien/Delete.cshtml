@model FurryFriends.API.Models.NhanVien

@{
    ViewData["Title"] = "Xóa nhân viên";
}

<h2>@ViewData["Title"]</h2>

<h3>Bạn có chắc muốn xóa nhân viên này?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Họ và tên</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.HoVaTen)</dd>
        <dt class="col-sm-2">Chức vụ</dt>
        <dd class="col-sm-10">@(Model.ChucVu != null ? Model.ChucVu.TenChucVu : "N/A")</dd>
        <dt class="col-sm-2">Tài khoản</dt>
        <dd class="col-sm-10">@(Model.TaiKhoan != null ? Model.TaiKhoan.UserName : "N/A")</dd>
        <dt class="col-sm-2">Trạng thái</dt>
        <dd class="col-sm-10">@(Model.TrangThai ? "Hoạt động" : "Không hoạt động")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="NhanVienId" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>