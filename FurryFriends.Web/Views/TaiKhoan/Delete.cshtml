@model FurryFriends.API.Models.TaiKhoan

@{
    ViewData["Title"] = "Xóa tài khoản";
}

<h2>@ViewData["Title"]</h2>

<h3>Bạn có chắc muốn xóa tài khoản này?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Tên đăng nhập</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.UserName)</dd>
        <dt class="col-sm-2">Trạng thái</dt>
        <dd class="col-sm-10">@(Model.TrangThai ? "Hoạt động" : "Không hoạt động")</dd>
        <dt class="col-sm-2">Ngày tạo</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.NgayTaoTaiKhoan)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="TaiKhoanId" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>