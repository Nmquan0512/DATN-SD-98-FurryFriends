@model FurryFriends.Web.Models.LoginRequest
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập - FurryFriends</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        /* --- Toàn bộ CSS như bạn gửi (rút gọn trong bản này để ngắn gọn) --- */
        /* Bạn có thể paste nguyên CSS ở view trước vào đây nếu muốn đầy đủ */
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            position: relative;
        }

        .login-container {
            background: #fff;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            max-width: 400px;
            width: 100%;
            z-index: 2;
            position: relative;
        }

        .form-group {
            margin-bottom: 20px;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        .login-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            color: white;
            padding: 12px;
            width: 100%;
            border-radius: 10px;
            font-size: 16px;
            cursor: pointer;
        }

        .walking-cat {
            position: absolute;
            top: -45px;
            width: 80px;
            height: 55px;
            animation: catWalk 12s ease-in-out infinite;
            z-index: 10;
        }

        .walking-cat img {
            width: 100%;
        }

        @@keyframes catWalk {
            0% { left: 20px; transform: scaleX(1); }
            45% { left: calc(100% - 100px); transform: scaleX(1); }
            50% { left: calc(100% - 100px); transform: scaleX(-1); }
            95% { left: 20px; transform: scaleX(-1); }
            100% { left: 20px; transform: scaleX(1); }
        }

        .error-message {
            color: red;
            margin-bottom: 10px;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="walking-cat">
        <img src="https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExdHBtcjdycHN5YjNrZmpqcHM3Zm1wN3hsbm84aTU3d3M4cTJsMmRxdyZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/jlw3OMYrH6mb4loQJI/giphy.gif" alt="Walking Cat" />
    </div>

    <div class="login-container">
        <h2 style="text-align:center; margin-bottom: 20px;">🐾 FurryFriends - Đăng nhập</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error-message">@ViewBag.Error</div>
        }

        <form asp-action="DangNhap" asp-controller="Auth" method="post">
            <div class="form-group">
                <label>Tên đăng nhập</label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="login-btn">Đăng nhập</button>
        </form>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
